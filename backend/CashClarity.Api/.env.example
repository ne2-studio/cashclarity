# Supabase project URL (used to verify JWTs via the auth API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (sent as apikey header to the auth API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection string (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
